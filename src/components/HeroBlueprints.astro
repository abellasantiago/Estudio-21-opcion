---
/*
 * HeroBlueprints — easter egg: "plano" oculto que flanquea el "21" (zona
 * izquierda, PLANTA: rectángulo cerrado con ambientes, entrada con barrido,
 * baño, cocina, living (sillón + TV), cota y norte). Decoración pura
 * (aria-hidden).
 *
 * Se descubre TIPO LÁPIZ: sólo se dibuja la PORCIÓN de línea por la que el
 * cursor pasa por encima (cobertura por segmentos). Lo que no recorrés no
 * aparece. Al sacar el cursor se desvanece y se resetea (vuelve a dormir).
 * Además, su opacidad se ata a --hero-fade (mismo mecanismo que .lbg-note):
 * se desvanece al dejar el hero con scroll y reaparece al volver arriba.
 *
 * Sólo en desktop con puntero fino y sin prefers-reduced-motion.
 */
import '../styles/hero-blueprints.css';
---

<!-- ZONA IZQUIERDA — planta -->
<div class="hero-zone hero-zone-left" aria-hidden="true" data-blueprint>
  <svg class="bp-svg" viewBox="0 0 210 214" fill="none">
    <!-- envolvente exterior, con vano de entrada en el muro sur -->
    <path class="bp-draw" d="M24 24 H186" />
    <path class="bp-draw" d="M186 24 V186" />
    <path class="bp-draw" d="M186 186 H84" />
    <path class="bp-draw" d="M60 186 H24" />
    <path class="bp-draw" d="M24 186 V24" />
    <!-- entrada: hoja (recta) + barrido (arco) -->
    <path class="bp-draw" d="M60 186 V162" />
    <path class="bp-draw" d="M60 162 A24 24 0 0 1 84 186" />
    <!-- muro interior con vano de puerta (hueco y58–84) -->
    <path class="bp-draw" d="M116 24 V58" />
    <path class="bp-draw" d="M116 84 V104" />
    <path class="bp-draw" d="M116 104 H186" />
    <!-- puerta: hoja (recta) + barrido (arco), mismo trazo que el resto -->
    <path class="bp-draw" d="M116 84 H90" />
    <path class="bp-draw" d="M116 58 A26 26 0 0 0 90 84" />
    <!-- living: sillón + TV -->
    <path class="bp-draw" d="M146 154 H180 V180 H146 Z" />
    <path class="bp-draw" d="M146 172 H180" />
    <path class="bp-draw" d="M150 106 H178 V110 H150 Z" />
    <!-- cocina (mesada en L) -->
    <path class="bp-draw" d="M32 32 H72 M32 32 V66" />
    <!-- cota inferior + norte -->
    <path class="bp-draw" d="M24 198 H186 M24 194 V202 M186 194 V202" />
    <path class="bp-draw" d="M196 30 V54 M196 30 l-4 8 M196 30 l4 8" />
    <!-- dormitorio: cama (pies hacia la pared de la puerta, al oeste) + cabecera al este + mesas de luz (minidetalle) -->
    <path class="bp-draw" d="M146 40 H184 V68 H146 Z" />
    <path class="bp-draw" d="M176 40 V68" />
    <path class="bp-draw" d="M174 28 H184 V38 H174 Z" />
    <path class="bp-draw" d="M174 70 H184 V80 H174 Z" />
    <!-- cota izquierda -->
    <path class="bp-draw" d="M14 26 V184 M10 26 H18 M10 184 H18" />
    <text class="bp-label" x="8" y="105" transform="rotate(-90 8 105)" text-anchor="middle">6.30</text>
    <text class="bp-label" x="36" y="46" text-anchor="start">PLANTA</text>
    <text class="bp-label" x="196" y="66" text-anchor="middle">N</text>
    <text class="bp-label" x="105" y="211" text-anchor="middle">8.40</text>
  </svg>
</div>

<script>
  // Sólo puntero fino y sin reduced-motion (mismo criterio que la capa inmersiva).
  const fine = window.matchMedia('(pointer: fine)');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (fine.matches && !reduce.matches) {
    const SEG = 6; // largo de cada segmento interno de línea (unidades del viewBox)
    const THRESHOLD = 17; // radio del "haz de linterna" que descubre la línea al pasar
    const TH2 = THRESHOLD * THRESHOLD;
    const DRAW_OPACITY = 0.62; // opacidad plena del trazo revelado (ver .bp-draw)
    const clampN = (v: number, a: number, b: number) => Math.min(b, Math.max(a, v));

    type Stroke = {
      el: SVGPathElement;
      len: number;
      n: number;
      mids: Array<[number, number]>;
      covered: boolean[];
      dirty: boolean;
    };

    document.querySelectorAll<HTMLElement>('[data-blueprint]').forEach((zone) => {
      const svg = zone.querySelector('svg') as SVGSVGElement | null;
      if (!svg) return;
      const point = svg.createSVGPoint();

      // segmentar cada línea y precomputar el punto medio de cada segmento
      const strokes: Stroke[] = Array.from(zone.querySelectorAll<SVGPathElement>('.bp-draw')).map(
        (el) => {
          const len = el.getTotalLength();
          const n = Math.max(4, Math.round(len / SEG));
          const mids: Array<[number, number]> = [];
          for (let i = 0; i < n; i++) {
            const p = el.getPointAtLength((len * (i + 0.5)) / n);
            mids.push([p.x, p.y]);
          }
          return { el, len, n, mids, covered: new Array(n).fill(false), dirty: false };
        },
      );
      const labels = Array.from(zone.querySelectorAll<SVGTextElement>('.bp-label')).map((el) => ({
        el,
        x: parseFloat(el.getAttribute('x') || '0'),
        y: parseFloat(el.getAttribute('y') || '0'),
        shown: false,
      }));

      let active = false;
      let last: { x: number; y: number } | null = null;

      // reconstruye el dash pattern mostrando sólo los segmentos ya recorridos
      const applyStroke = (s: Stroke) => {
        const seg = s.len / s.n;
        const dash: number[] = [];
        let cur = s.covered[0];
        if (!cur) dash.push(0); // el patrón arranca con un "trazo" visible
        let run = 0;
        for (let i = 0; i < s.n; i++) {
          if (s.covered[i] === cur) run += seg;
          else {
            dash.push(run);
            cur = s.covered[i];
            run = seg;
          }
        }
        dash.push(run);
        s.el.style.strokeDasharray = dash.join(' ');
        // fade-in suave por trazo: la opacidad crece con la fracción recorrida
        // (transición CSS en .bp-draw) → nunca "pop", se dibuja como a lápiz.
        let cov = 0;
        for (let i = 0; i < s.n; i++) if (s.covered[i]) cov++;
        const frac = cov / s.n;
        s.el.style.strokeOpacity = (DRAW_OPACITY * clampN(0.4 + frac, 0, 1)).toFixed(3);
      };
      const hideStroke = (s: Stroke) => {
        s.el.style.strokeDasharray = '0 ' + s.len;
        s.el.style.strokeOpacity = '0';
      };

      const coverAt = (lx: number, ly: number) => {
        for (const s of strokes) {
          for (let i = 0; i < s.n; i++) {
            if (s.covered[i]) continue;
            const dx = s.mids[i][0] - lx;
            const dy = s.mids[i][1] - ly;
            if (dx * dx + dy * dy < TH2) {
              s.covered[i] = true;
              s.dirty = true;
            }
          }
        }
      };

      const onMove = (e: PointerEvent) => {
        if (!active) return;
        const m = svg.getScreenCTM();
        if (!m) return;
        point.x = e.clientX;
        point.y = e.clientY;
        const loc = point.matrixTransform(m.inverse());
        if (last) {
          // interpolar el recorrido para no dejar huecos al mover rápido
          const dist = Math.hypot(loc.x - last.x, loc.y - last.y);
          const steps = Math.max(1, Math.ceil(dist / (THRESHOLD * 0.7)));
          for (let k = 1; k <= steps; k++) {
            const t = k / steps;
            coverAt(last.x + (loc.x - last.x) * t, last.y + (loc.y - last.y) * t);
          }
        } else {
          coverAt(loc.x, loc.y);
        }
        last = { x: loc.x, y: loc.y };
        for (const s of strokes) {
          if (s.dirty) {
            applyStroke(s);
            s.dirty = false;
          }
        }
        // rótulos: aparecen al pasar por encima de su posición
        for (const l of labels) {
          if (l.shown) continue;
          if (Math.hypot(l.x - loc.x, l.y - loc.y) < 14) {
            l.shown = true;
            l.el.style.opacity = '1';
          }
        }
      };

      // reset SÓLO al inicializar: deja el plano en blanco y dormido. Al salir
      // con el cursor NO se resetea — lo dibujado persiste, sólo se atenúa.
      const reset = () => {
        for (const s of strokes) {
          s.covered.fill(false);
          s.dirty = false;
          hideStroke(s);
        }
        for (const l of labels) {
          l.shown = false;
          l.el.style.opacity = '0';
        }
        zone.classList.remove('is-drawn');
        last = null;
      };

      const hasDrawing = () => strokes.some((s) => s.covered.some(Boolean));

      zone.addEventListener('pointerenter', () => {
        active = true;
        last = null;
        // recupera opacidad plena de todo el dibujo (is-active gana a is-drawn)
        zone.classList.add('is-active');
      });
      zone.addEventListener('pointermove', onMove);
      zone.addEventListener('pointerleave', () => {
        active = false;
        zone.classList.remove('is-active');
        // el plano queda dibujado, "durmiendo" muy tenue (no se borra ni resetea)
        if (hasDrawing()) zone.classList.add('is-drawn');
      });

      reset();
    });
  }
</script>
