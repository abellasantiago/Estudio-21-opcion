---
/*
 * HeroBlueprints — easter egg: dos "planos" ocultos que flanquean el "21".
 *
 * Cada zona es un área invisible en el espacio vacío del hero. El plano se
 * descubre TIPO LÁPIZ: sólo se dibuja la PORCIÓN de línea por la que el cursor
 * pasa por encima (cobertura por segmentos). Lo que no recorrés no aparece. Al
 * sacar el cursor se desvanece y se resetea (vuelve a dormir).
 *
 * Zona izquierda: PLANTA (rectángulo cerrado con ambientes, puerta con barrido,
 * baño, cocina, escalera, cota y norte). Zona derecha: FACHADA (envolvente,
 * cornisa, entrepisos, grilla de ventanas, puerta y cota). Decoración pura
 * (aria-hidden). Sólo en desktop con puntero fino y sin prefers-reduced-motion.
 */
import '../styles/hero-blueprints.css';
---

<!-- ZONA IZQUIERDA — planta -->
<div class="hero-zone hero-zone-left" aria-hidden="true" data-blueprint>
  <svg class="bp-svg" viewBox="0 0 210 214" fill="none">
    <path class="bp-draw" d="M24 24 H186 V186 H24 Z" />
    <path class="bp-draw" d="M116 24 V104" />
    <path class="bp-draw" d="M116 104 H186" />
    <path class="bp-draw" d="M24 128 H78 V186" />
    <path class="bp-draw bp-accent" d="M116 58 A26 26 0 0 0 90 84" />
    <path class="bp-draw" d="M150 138 H178 V178 H150 Z" />
    <path class="bp-draw" d="M150 156 H178" />
    <path class="bp-draw" d="M32 32 H72 M32 32 V66" />
    <path class="bp-draw" d="M88 128 V186 M108 128 V186" />
    <path class="bp-draw" d="M88 142 H108 M88 156 H108 M88 170 H108" />
    <path class="bp-draw" d="M24 198 H186 M24 194 V202 M186 194 V202" />
    <path class="bp-draw" d="M196 30 V54 M196 30 l-4 8 M196 30 l4 8" />
    <text class="bp-label" x="36" y="46" text-anchor="start">PLANTA</text>
    <text class="bp-label" x="196" y="66" text-anchor="middle">N</text>
    <text class="bp-label" x="105" y="211" text-anchor="middle">8.40</text>
  </svg>
</div>

<!-- ZONA DERECHA — fachada -->
<div class="hero-zone hero-zone-right" aria-hidden="true" data-blueprint>
  <svg class="bp-svg" viewBox="0 0 200 212" fill="none">
    <path class="bp-draw" d="M6 192 H194" />
    <path class="bp-draw" d="M34 44 H166 V192 H34 Z" />
    <path class="bp-draw" d="M28 44 H172 M28 44 V36 H172 V44" />
    <path class="bp-draw" d="M34 96 H166" />
    <path class="bp-draw" d="M34 144 H166" />
    <path class="bp-draw" d="M50 84 H74 V56 H50 Z" />
    <path class="bp-draw" d="M88 84 H112 V56 H88 Z" />
    <path class="bp-draw" d="M126 84 H150 V56 H126 Z" />
    <path class="bp-draw" d="M50 132 H74 V104 H50 Z" />
    <path class="bp-draw" d="M88 132 H112 V104 H88 Z" />
    <path class="bp-draw" d="M126 132 H150 V104 H126 Z" />
    <path class="bp-draw" d="M64 192 V152 H92 V192" />
    <path class="bp-draw" d="M120 180 H150 V152 H120 Z" />
    <path class="bp-draw bp-accent" d="M20 44 V192 M16 44 H24 M16 192 H24" />
    <text class="bp-label" x="100" y="208" text-anchor="middle">FACHADA</text>
    <text class="bp-label" x="12" y="120" transform="rotate(-90 12 120)" text-anchor="middle">12.60</text>
  </svg>
</div>

<script>
  // Sólo puntero fino y sin reduced-motion (mismo criterio que la capa inmersiva).
  const fine = window.matchMedia('(pointer: fine)');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (fine.matches && !reduce.matches) {
    const SEG = 6; // largo de cada segmento interno de línea (unidades del viewBox)
    const THRESHOLD = 9; // radio del "haz de linterna" que descubre la línea al pasar
    const TH2 = THRESHOLD * THRESHOLD;

    type Stroke = {
      el: SVGPathElement;
      len: number;
      n: number;
      mids: Array<[number, number]>;
      covered: boolean[];
      dirty: boolean;
    };

    document.querySelectorAll<HTMLElement>('[data-blueprint]').forEach((zone) => {
      const svg = zone.querySelector('svg') as SVGSVGElement | null;
      if (!svg) return;
      const point = svg.createSVGPoint();

      // segmentar cada línea y precomputar el punto medio de cada segmento
      const strokes: Stroke[] = Array.from(zone.querySelectorAll<SVGPathElement>('.bp-draw')).map(
        (el) => {
          const len = el.getTotalLength();
          const n = Math.max(4, Math.round(len / SEG));
          const mids: Array<[number, number]> = [];
          for (let i = 0; i < n; i++) {
            const p = el.getPointAtLength((len * (i + 0.5)) / n);
            mids.push([p.x, p.y]);
          }
          return { el, len, n, mids, covered: new Array(n).fill(false), dirty: false };
        },
      );
      const labels = Array.from(zone.querySelectorAll<SVGTextElement>('.bp-label')).map((el) => ({
        el,
        x: parseFloat(el.getAttribute('x') || '0'),
        y: parseFloat(el.getAttribute('y') || '0'),
        shown: false,
      }));

      let active = false;
      let resetTimer = 0;
      let last: { x: number; y: number } | null = null;

      // reconstruye el dash pattern mostrando sólo los segmentos ya recorridos
      const applyStroke = (s: Stroke) => {
        const seg = s.len / s.n;
        const dash: number[] = [];
        let cur = s.covered[0];
        if (!cur) dash.push(0); // el patrón arranca con un "trazo" visible
        let run = 0;
        for (let i = 0; i < s.n; i++) {
          if (s.covered[i] === cur) run += seg;
          else {
            dash.push(run);
            cur = s.covered[i];
            run = seg;
          }
        }
        dash.push(run);
        s.el.style.strokeDasharray = dash.join(' ');
      };
      const hideStroke = (s: Stroke) => {
        s.el.style.strokeDasharray = '0 ' + s.len;
      };

      const coverAt = (lx: number, ly: number) => {
        for (const s of strokes) {
          for (let i = 0; i < s.n; i++) {
            if (s.covered[i]) continue;
            const dx = s.mids[i][0] - lx;
            const dy = s.mids[i][1] - ly;
            if (dx * dx + dy * dy < TH2) {
              s.covered[i] = true;
              s.dirty = true;
            }
          }
        }
      };

      const onMove = (e: PointerEvent) => {
        if (!active) return;
        const m = svg.getScreenCTM();
        if (!m) return;
        point.x = e.clientX;
        point.y = e.clientY;
        const loc = point.matrixTransform(m.inverse());
        if (last) {
          // interpolar el recorrido para no dejar huecos al mover rápido
          const dist = Math.hypot(loc.x - last.x, loc.y - last.y);
          const steps = Math.max(1, Math.ceil(dist / (THRESHOLD * 0.7)));
          for (let k = 1; k <= steps; k++) {
            const t = k / steps;
            coverAt(last.x + (loc.x - last.x) * t, last.y + (loc.y - last.y) * t);
          }
        } else {
          coverAt(loc.x, loc.y);
        }
        last = { x: loc.x, y: loc.y };
        for (const s of strokes) {
          if (s.dirty) {
            applyStroke(s);
            s.dirty = false;
          }
        }
        // rótulos: aparecen al pasar por encima de su posición
        for (const l of labels) {
          if (l.shown) continue;
          if (Math.hypot(l.x - loc.x, l.y - loc.y) < 12) {
            l.shown = true;
            l.el.style.opacity = '1';
          }
        }
      };

      const reset = () => {
        for (const s of strokes) {
          s.covered.fill(false);
          s.dirty = false;
          hideStroke(s);
        }
        for (const l of labels) {
          l.shown = false;
          l.el.style.opacity = '0';
        }
        last = null;
      };

      zone.addEventListener('pointerenter', () => {
        window.clearTimeout(resetTimer);
        active = true;
        last = null;
        zone.classList.add('is-active');
      });
      zone.addEventListener('pointermove', onMove);
      zone.addEventListener('pointerleave', () => {
        active = false;
        zone.classList.remove('is-active'); // dispara el fade-out (CSS)
        resetTimer = window.setTimeout(reset, 520); // resetea al terminar el fade
      });

      reset();
    });
  }
</script>
