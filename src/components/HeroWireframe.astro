---
/*
 * HeroWireframe — pabellón vidriado en wireframe, PROYECCIÓN 3D REAL a dos
 * puntos de fuga, fondo del "21".
 *
 * En vez de dibujar "a ojo", acá hay una escena de verdad: una cámara pinhole
 * (focal F, altura de ojo EYE) y una nave modernista girada ~32° respecto del
 * plano de cuadro. De ese giro salen los DOS puntos de fuga francos:
 *   · VPR (eje longitudinal de la nave) cae EN CUADRO a la derecha del "21",
 *     sobre el horizonte bajo (tercio inferior de los dígitos);
 *   · VPL (profundidad de la nave) cae fuera de cuadro a la izquierda, cerca
 *     (≈ −650), así las cerchas de cubierta, el testero y las baldosas
 *     transversales convergen con pendiente bien visible → la segunda fuga
 *     se LEE, no es teórica.
 *
 * La nave corre de u=−19 m (viene hacia cámara: el tramo cercano se agranda y
 * sube saliendo por arriba-izquierda, detrás de "ESTUDIO") a u=+140 m (se
 * comprime contra VPR). El "21" tapa el tramo central. Detalle arquitectónico:
 * columnata a paso real (opacidad según distancia), segunda fila de columnas,
 * cubierta con borde + fascia, PARRILLA de techo (cerchas transversales a VPL
 * + correas longitudinales a VPR), carpinterías del vidriado (dos rieles +
 * montantes a medio vano en los tramos cercanos), zócalo, testero, baldosado
 * de piso en LAS DOS direcciones y prolongaciones tenues de boceto.
 *
 * En modo inmersivo aparece suavemente con el movimiento del mouse
 * (--wf-reveal, lo escribe immersive.ts) y se va con --hero-fade. Sin JS /
 * reduced-motion queda visible estático y tenue; oculto en <900px.
 * Decoración pura (aria-hidden).
 */
import '../styles/hero-wireframe.css';

// ---- cámara y escena (unidades en metros; pantalla = viewBox 1600×900) ----
const F = 900; // focal en px
const CX = 800; // eje óptico (el "21" está centrado)
const HOR = 512; // horizonte: tercio inferior de los dígitos
const EYE = 1.65; // altura del ojo
const ALPHA = (31.9 * Math.PI) / 180; // giro de la nave → fija ambos VPs
const AX = Math.sin(ALPHA);
const AZ = Math.cos(ALPHA); // eje longitudinal (u) → VPR ≈ (1360, HOR)
const BX = -Math.cos(ALPHA);
const BZ = Math.sin(ALPHA); // profundidad (v) → VPL ≈ (−647, HOR)
const O = { x: 4.67, z: 30 }; // esquina u=0,v=0: frente de la nave, detrás del "21"

const H = 5.2; // altura de la nave
const D = 7; // profundidad de la nave
const BAY = 3.2; // paso de columnas
const U0 = -19.2; // extremo cercano (sale de cuadro arriba-izquierda)
const U1 = 140; // extremo lejano (testero, comprimido contra VPR)

type Sp = { x: number; y: number; z: number };
// proyecta el punto (u,v,h) de coordenadas de la nave a pantalla
const pt = (u: number, v: number, h: number): Sp => {
  const wx = O.x + u * AX + v * BX;
  const wz = O.z + u * AZ + v * BZ;
  return { x: +(CX + (F * wx) / wz).toFixed(1), y: +(HOR + (F * (EYE - h)) / wz).toFixed(1), z: wz };
};

type Line = { d: string; o: number };
const lines: Line[] = [];
const L = (a: Sp, b: Sp, o: number) =>
  lines.push({ d: `M${a.x} ${a.y} L${b.x} ${b.y}`, o: +o.toFixed(2) });

// ---- horizontales del plano frontal (recorren toda la nave → fugan a VPR) ----
L(pt(U0, 0, H), pt(U1, 0, H), 0.34); // borde de cubierta
L(pt(U0, 0, H - 0.55), pt(U1, 0, H - 0.55), 0.2); // fascia
L(pt(U0, 0, 3.35), pt(U1, 0, 3.35), 0.15); // riel alto del vidriado
L(pt(U0, 0, 2.05), pt(U1, 0, 2.05), 0.16); // riel bajo
L(pt(U0, 0, 0.45), pt(U1, 0, 0.45), 0.15); // zócalo
L(pt(U0, 0, 0), pt(U1, 0, 0), 0.32); // línea de piso

// ---- plano de fondo ----
L(pt(U0, D, H), pt(U1, D, H), 0.16); // cubierta de atrás
L(pt(-6.4, D, 0), pt(U1, D, 0), 0.12); // piso de atrás

// ---- parrilla de cubierta: correas longitudinales (→ VPR) ----
L(pt(U0, D / 3, H), pt(U1, D / 3, H), 0.12);
L(pt(U0, (2 * D) / 3, H), pt(U1, (2 * D) / 3, H), 0.12);

// ---- columnata frontal (paso real; opacidad según distancia) ----
for (let i = -6; i <= 43; i++) {
  const u = i * BAY;
  const a = pt(u, 0, 0);
  const b = pt(u, 0, H);
  L(a, b, Math.min(0.3, 0.07 + 4.5 / a.z));
}
// segunda fila de columnas (atrás, cada tres vanos)
for (let i = -6; i <= 43; i += 3) {
  const u = i * BAY;
  const a = pt(u, D, 0);
  const b = pt(u, D, H);
  L(a, b, Math.min(0.14, 0.04 + 2 / a.z));
}

// ---- cerchas transversales de cubierta (→ VPL: la segunda fuga se lee acá) ----
for (let i = -6; i <= 16; i++) {
  const u = i * BAY;
  const a = pt(u, 0, H);
  L(a, pt(u, D, H), Math.min(0.16, 0.05 + 2.2 / a.z));
}
for (let i = 18; i <= 42; i += 3) {
  const u = i * BAY;
  L(pt(u, 0, H), pt(u, D, H), 0.09);
}

// ---- montantes del vidriado a medio vano (sólo tramos cercanos) ----
for (let i = -5; i <= 7; i++) {
  const u = (i + 0.5) * BAY;
  L(pt(u, 0, 0.45), pt(u, 0, 3.35), 0.09);
}

// ---- testero (extremo lejano) ----
L(pt(U1, 0, 0), pt(U1, D, 0), 0.14);
L(pt(U1, 0, H), pt(U1, D, H), 0.14);
L(pt(U1, D, 0), pt(U1, D, H), 0.14);

// ---- baldosado de piso delante de la nave (dos direcciones = dos fugas) ----
for (let j = 1; j <= 4; j++) {
  L(pt(U0, -2 * j, 0), pt(U1 * 0.75, -2 * j, 0), 0.15 - j * 0.02);
}
for (let i = -2; i <= 7; i++) {
  const u = i * 6.4;
  L(pt(u, -8, 0), pt(u, 0, 0), 0.1);
}

// ---- prolongaciones de boceto más allá del testero ----
L(pt(U1, 0, H), pt(U1 + 70, 0, H), 0.09);
L(pt(U1, 0, 0), pt(U1 + 70, 0, 0), 0.08);
---

<div class="hero-wireframe" aria-hidden="true" data-wireframe data-depth="0.07">
  <svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
    {lines.map((l) => <path d={l.d} stroke-opacity={l.o} />)}
  </svg>
</div>
