---
/*
 * HeroWireframe — pabellón vidriado en wireframe, PROYECCIÓN 3D REAL a dos
 * puntos de fuga, fondo del "21".
 *
 * En vez de dibujar "a ojo", acá hay una escena de verdad: una cámara pinhole
 * (focal F, altura de ojo EYE) y una nave girada 38° respecto del plano de
 * cuadro. La ESQUINA de la nave (el vértice) queda detrás del "2": de ahí las
 * líneas fugan hacia los dos lados —
 *   · a la DERECHA la fachada larga (eje u → VPR ≈ (1500, HOR), casi en el
 *     borde del cuadro): mucho más recorrido, y el dibujo se DISPERSA contra
 *     la fuga con un fade propio del SVG (máscara con degradé horizontal);
 *   · a la IZQUIERDA la fachada corta / testero (eje v → VPL ≈ (−350, HOR),
 *     fuera de cuadro pero cerca → pendiente bien visible), recorrido corto.
 *
 * Trazo arquitectónico denso pero tenue: columnata a paso real (opacidad según
 * distancia), rieles y montantes del vidriado, cubierta con fascia, cerchas a
 * dos cordones con montantes en los tramos cercanos, correas longitudinales,
 * segunda fila de columnas, testero lejano, baldosado de piso en las dos
 * direcciones y prolongaciones de boceto más allá de la esquina (salen hacia
 * arriba-izquierda, detrás de "ESTUDIO") y de los extremos.
 *
 * En modo inmersivo aparece suavemente con el movimiento del mouse
 * (--wf-reveal, lo escribe immersive.ts) y se va con --hero-fade. Sin JS /
 * reduced-motion queda visible estático y tenue; oculto en <900px.
 * Decoración pura (aria-hidden).
 */
import '../styles/hero-wireframe.css';

// ---- cámara y escena (unidades en metros; pantalla = viewBox 1600×900) ----
const F = 900; // focal en px
const CX = 800; // eje óptico (el "21" está centrado)
const HOR = 510; // horizonte bajo: tercio inferior de los dígitos
const EYE = 1.65; // altura del ojo
const ALPHA = (38 * Math.PI) / 180; // giro de la nave → fija ambos VPs
const AX = Math.sin(ALPHA);
const AZ = Math.cos(ALPHA); // fachada larga (u) → VPR ≈ (1503, HOR)
const BX = -Math.cos(ALPHA);
const BZ = Math.sin(ALPHA); // fachada corta (v) → VPL ≈ (−352, HOR)
// esquina u=0,v=0: el vértice, detrás del "2" (a 20 m → la nave queda BAJA
// respecto de los dígitos y su línea de piso sube hacia el horizonte: mismo
// plano de suelo que el "21", pero más atrás — fondo, sin protagonismo)
const O = { x: -2.11, z: 20 };

const H = 4.6; // altura de la nave
const FASCIA = H - 0.45; // cordón inferior de fascia/cercha
const BAY = 3.2; // paso de columnas
const UB = 36 * BAY; // largo de la fachada derecha (115,2 m → contra VPR)
const LV = 5 * BAY; // fondo de la fachada izquierda (16 m, recorrido corto)

type Sp = { x: number; y: number; z: number };
// proyecta el punto (u,v,h) de coordenadas de la nave a pantalla
const pt = (u: number, v: number, h: number): Sp => {
  const wx = O.x + u * AX + v * BX;
  const wz = O.z + u * AZ + v * BZ;
  return { x: +(CX + (F * wx) / wz).toFixed(1), y: +(HOR + (F * (EYE - h)) / wz).toFixed(1), z: wz };
};

type Line = { d: string; o: number };
const lines: Line[] = [];
const L = (a: Sp, b: Sp, o: number) =>
  lines.push({ d: `M${a.x} ${a.y} L${b.x} ${b.y}`, o: +o.toFixed(2) });

// ---- horizontales de las dos fachadas (nacen en el vértice) ----
const RAILS: [number, number][] = [
  [H, 0.3], // borde de cubierta
  [FASCIA, 0.16], // fascia
  [3.1, 0.14], // riel alto del vidriado
  [1.95, 0.14], // riel bajo
  [0.45, 0.13], // zócalo
  [0, 0.28], // línea de piso
];
for (const [h, o] of RAILS) L(pt(0, 0, h), pt(UB, 0, h), o); // → derecha (VPR)
for (const [h, o] of RAILS) L(pt(0, LV, h), pt(0, 0, h), o * 0.85); // → izquierda (VPL)

// ---- columnata de la fachada larga (paso real; opacidad según distancia) ----
for (let i = 0; i <= 36; i++) {
  const a = pt(i * BAY, 0, 0);
  L(a, pt(i * BAY, 0, H), Math.min(0.26, 0.05 + 3.2 / a.z));
}
// montantes del vidriado a medio vano (se van rarificando con la distancia)
for (let i = 0; i <= 24; i++) {
  const u = (i + 0.5) * BAY;
  const a = pt(u, 0, 0.45);
  L(a, pt(u, 0, 3.1), Math.min(0.08, 0.015 + 0.8 / a.z));
}

// ---- columnata de la fachada corta (izquierda) + sus montantes ----
for (let j = 1; j <= 5; j++) {
  const a = pt(0, j * BAY, 0);
  L(a, pt(0, j * BAY, H), Math.min(0.2, 0.04 + 2.4 / a.z));
}
for (let j = 0; j <= 4; j++) {
  const v = (j + 0.5) * BAY;
  L(pt(0, v, 0.45), pt(0, v, 3.1), 0.07);
}

// ---- plano de fondo (lado lejano de la nave, v=LV) ----
L(pt(0, LV, H), pt(UB, LV, H), 0.12); // cubierta de atrás
L(pt(0, LV, 3.1), pt(UB, LV, 3.1), 0.07); // riel alto de atrás
L(pt(0, LV, 0), pt(UB, LV, 0), 0.09); // piso de atrás
for (let i = 0; i <= 36; i += 3) {
  const a = pt(i * BAY, LV, 0);
  L(a, pt(i * BAY, LV, H), Math.min(0.09, 0.02 + 1.2 / a.z));
}

// ---- cubierta: cerchas transversales (→ VPL) + correas longitudinales (→ VPR) ----
for (let i = 0; i <= 36; i++) {
  if (i > 18 && i % 2 === 1) continue; // contra la fuga se rarifican
  const a = pt(i * BAY, 0, H);
  L(a, pt(i * BAY, LV, H), Math.min(0.13, 0.035 + 1.5 / a.z));
}
for (let k = 1; k <= 3; k++) {
  L(pt(0, (k * LV) / 4, H), pt(UB, (k * LV) / 4, H), 0.1);
}
// cerchas cercanas a dos cordones: cordón inferior + montantes de alma
for (let i = 1; i <= 6; i++) {
  const u = i * BAY;
  L(pt(u, 0, FASCIA), pt(u, LV, FASCIA), 0.06);
  for (let k = 1; k <= 3; k++) {
    const v = (k * LV) / 4;
    L(pt(u, v, FASCIA), pt(u, v, H), 0.06);
  }
}

// ---- testero lejano (u=UB; la máscara lo termina de dispersar) ----
L(pt(UB, 0, H), pt(UB, LV, H), 0.1);
L(pt(UB, 0, 0), pt(UB, LV, 0), 0.09);
L(pt(UB, LV, 0), pt(UB, LV, H), 0.08);

// ---- baldosado de piso delante de la nave (dos direcciones = dos fugas) ----
for (let j = 1; j <= 3; j++) {
  L(pt(-6, -2 * j, 0), pt(90, -2 * j, 0), 0.13 - j * 0.03);
}
for (let i = -1; i <= 10; i++) {
  const a = pt(i * 6.4, -6, 0);
  L(a, pt(i * 6.4, 0, 0), Math.min(0.09, 0.02 + 0.9 / a.z));
}

// ---- prolongaciones de boceto ----
// hacia atrás de la esquina (vienen hacia cámara: salen arriba-izquierda,
// detrás de "ESTUDIO" — como trazos de construcción del dibujo)
for (const h of [H, 3.1, 0]) L(pt(-12, 0, h), pt(0, 0, h), 0.08);
// más allá del testero derecho (la fuga sigue y se dispersa con el fade)
L(pt(UB, 0, H), pt(UB + 70, 0, H), 0.07);
L(pt(UB, 0, 0), pt(UB + 70, 0, 0), 0.07);
// más allá del fondo izquierdo
L(pt(0, LV + 8, H), pt(0, LV, H), 0.06);
L(pt(0, LV + 8, 0), pt(0, LV, 0), 0.06);
---

<div class="hero-wireframe" aria-hidden="true" data-wireframe data-depth="0.07">
  <svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- dispersión contra la fuga derecha: el dibujo se apaga de a poco
           mucho antes del VPR (≈1503) → fade out bien lejano -->
      <linearGradient id="wf-fade-vpr" gradientUnits="userSpaceOnUse" x1="1000" y1="0" x2="1400" y2="0">
        <stop offset="0" stop-color="#fff" />
        <stop offset="0.55" stop-color="#777" />
        <stop offset="1" stop-color="#000" />
      </linearGradient>
      <mask id="wf-fade">
        <rect x="0" y="0" width="1600" height="900" fill="url(#wf-fade-vpr)" />
      </mask>
    </defs>
    <g mask="url(#wf-fade)">
      {lines.map((l) => <path d={l.d} stroke-opacity={l.o} />)}
    </g>
  </svg>
</div>
