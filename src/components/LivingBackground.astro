---
/*
 * LivingBackground — el "espacio" 3D continuo detrás de toda la home.
 *
 * Capas (de atrás hacia adelante):
 *   · corredor de marcos de registro que retroceden en Z y AVANZAN hacia la
 *     cámara con el scroll (sensación de recorrer el estudio hero → cards);
 *   · fantasma "21" grande que gira lento durante el descenso (data-rotate);
 *   · un "21" secundario, anotaciones mono (coordenadas / código) y marcas de
 *     registro a pantalla completa, todo con paralaje de mouse/scroll + deriva.
 *
 * El motor (immersive.ts) mueve todo esto; sin JS queda un backdrop estático y
 * sutil. Las secciones del inicio y el helicoidal quedan transparentes (ver
 * immersive.css) para que este fondo se vea de forma continua = un mismo espacio.
 */
import '../styles/immersive.css';
import { site } from '../data/site';

// marcos del corredor: del más cercano al más lejano (cada uno a su translateZ).
const CORRIDOR_FRAMES = 7;
const frames = Array.from(
  { length: CORRIDOR_FRAMES },
  (_, i) => -700 - i * 300, // -700 (cerca) … -2500 (lejos)
);
---

<div class="living-bg" aria-hidden="true">
  <!-- corredor de marcos: profundidad real que avanza con el scroll -->
  <div class="depth-corridor" data-corridor>
    {frames.map((z) => (
      <span class="depth-frame" style={`--z:${z}px`}></span>
    ))}
  </div>

  <!-- "21" de fondo que gira lento durante todo el descenso -->
  <span class="lbg-ghost lbg-ghost-1" data-depth="0.05" data-scroll="-0.03" data-drift="16" data-rotate="150">21</span>
  <span class="lbg-ghost lbg-ghost-2" data-depth="0.12" data-scroll="0.05" data-drift="10">21</span>

  <span class="lbg-note lbg-note-1" data-depth="0.34" data-scroll="0.02" data-drift="6">
    {site.direccion.ciudad} · 34°54′S 56°11′O
  </span>
  <span class="lbg-note lbg-note-2" data-depth="0.5" data-scroll="-0.02" data-drift="8">
    EST·21 — Arquitectura y desarrollo
  </span>

  <span class="lbg-marks" data-depth="0.2" data-scroll="0.015">
    <span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span>
  </span>
</div>
