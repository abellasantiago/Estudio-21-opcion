---
/*
 * Preloader de la home: una planta arquitectónica minimalista que se dibuja
 * trazo por trazo (contorno → tabiques/aberturas → mobiliario). Al terminar,
 * TODO el overlay (papel + plano) se barre HACIA ARRIBA como un telón y deja
 * ver directamente el hero real: el "21" que ya viene girando en 3D detrás
 * (con sus "21" fantasma de fondo, que aparecen recién ahí). No hay "21"
 * intermedio — no se percibe ningún cambio de un 21 a otro. Se muestra UNA vez
 * por sesión del navegador (flag `e21-preloaded` en sessionStorage): la primera
 * carga lo dibuja; los reloads y el link "Inicio" (→ recarga `/`) dentro de esa
 * sesión lo saltean y van directo al hero. En una pestaña/sesión nueva vuelve a
 * aparecer como "primera vez".
 *
 * El plano es tenue y contenido (no protagonista): abajo, una barra de carga que
 * se completa + un porcentaje mono dejan claro que el sitio está "cargando".
 *
 * Plano depurado pero con oficio: la arquitectura esencial (muros a doble línea,
 * puertas con hoja + barrido que NO chocan con el mobiliario, ventanas sobre muro
 * exterior) más un mínimo de grafismo de plano — una cota general y escala
 * gráfica. Sin carátula ni rótulos de ambiente: minimalista.
 *
 * Fases (data-ph) → el script asigna los delays de cada trazo (dibujo pausado,
 * capa por capa, como un plano que se va levantando):
 *   1 = contorno (envolvente)
 *   2 = tabiques + aberturas (puertas, ventanas)
 *   3 = mobiliario y artefactos
 *   4 = grafismo: cota general y escala gráfica
 */
import '../styles/preloader.css';
---

<div class="preloader" id="preloader" role="status" aria-label="Cargando Estudio 21">
  <div class="pl-sheet">
    <svg
      class="pl-plan"
      viewBox="120 78 560 392"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <!-- ===================== FASE 1 · CONTORNO ===================== -->
      <g data-ph="1">
        <!-- envolvente: muro exterior a doble línea, con hueco de acceso al sur.
             La línea INTERIOR queda hueca justo donde entra cada tabique (arriba,
             a la derecha y abajo) — sin ese tramo no hay una raya cruzando entre
             las dos líneas del tabique: el muro se lee de una sola pieza y el
             tabique queda fundido en él, no "pegado" por encima. -->
        <path class="pl-wall pl-draw" pathLength="1" d="M162 138 H638 V412 H252 M210 412 H162 V138" />
        <path class="pl-wall pl-draw" pathLength="1" d="M174 150 H425 M435 150 H626 V303 M626 313 V400 H435 M425 400 H252 M210 400 H174 V150" />
      </g>

      <!-- ===================== FASE 2 · TABIQUES + ABERTURAS ===================== -->
      <g data-ph="2">
        <!-- tabique vertical (social | privado), con huecos de puertas. La línea
             izquierda (425) es continua de punta a punta; la derecha (435) se abre
             donde entra el tabique horizontal (303-313), por la misma razón. -->
        <path class="pl-part pl-draw" pathLength="1" d="M425 150 V165 M425 205 V320 M425 356 V400" />
        <path class="pl-part pl-draw" pathLength="1" d="M435 150 V165 M435 205 V303 M435 313 V320 M435 356 V400" />
        <!-- tabique horizontal (dormitorio | baño): corrido hacia abajo → dormitorio más amplio, baño más compacto -->
        <path class="pl-part pl-draw" pathLength="1" d="M435 303 H626" />
        <path class="pl-part pl-draw" pathLength="1" d="M435 313 H626" />

        <!-- jambas (cierran el espesor del muro en cada hueco) -->
        <path class="pl-thin pl-draw" pathLength="1" d="M210 400 V412 M252 400 V412" />
        <path class="pl-thin pl-draw" pathLength="1" d="M425 165 H435 M425 205 H435" />
        <path class="pl-thin pl-draw" pathLength="1" d="M425 320 H435 M425 356 H435" />

        <!-- puerta de acceso (hoja con hinge izq. + barrido hacia el estar) -->
        <path class="pl-door pl-draw" pathLength="1" d="M210 400 V358" />
        <path class="pl-door pl-draw" pathLength="1" d="M210 358 A42 42 0 0 1 252 400" />
        <!-- puerta dormitorio -->
        <path class="pl-door pl-draw" pathLength="1" d="M435 205 H475" />
        <path class="pl-door pl-draw" pathLength="1" d="M475 205 A40 40 0 0 0 435 165" />
        <!-- puerta baño (bisagra arriba del hueco, la hoja tuca contra el tabique) -->
        <path class="pl-door pl-draw" pathLength="1" d="M435 320 H471" />
        <path class="pl-door pl-draw" pathLength="1" d="M471 320 A36 36 0 0 1 435 356" />

        <!-- ventanas (sólo en muro exterior): jambas + vidrio -->
        <path class="pl-thin pl-draw" pathLength="1" d="M250 138 V150 M340 138 V150 M250 144 H340" />
        <path class="pl-thin pl-draw" pathLength="1" d="M300 400 V412 M380 400 V412 M300 406 H380" />
        <path class="pl-thin pl-draw" pathLength="1" d="M626 190 H638 M626 250 H638 M632 190 V250" />
        <!-- ventanita de ventilación del baño -->
        <path class="pl-thin pl-draw" pathLength="1" d="M626 360 H638 M626 386 H638 M632 360 V386" />
      </g>

      <!-- ===================== FASE 3 · MOBILIARIO ===================== -->
      <g data-ph="3" class="pl-fur">
        <!-- cocina: mesada en L + bacha + anafe -->
        <path class="pl-fur pl-fade" pathLength="1" d="M174 150 H300 V186 H210 V300 H174 Z" />
        <circle class="pl-fur pl-fade" pathLength="1" cx="250" cy="168" r="7" />
        <rect class="pl-fur pl-fade" pathLength="1" x="180" y="230" width="26" height="26" />

        <!-- comedor: mesa separada de la mesada (circulación) + 4 sillas -->
        <rect class="pl-fur pl-fade" pathLength="1" x="264" y="238" width="102" height="46" rx="6" />
        <rect class="pl-fur pl-fade" pathLength="1" x="281" y="216" width="22" height="15" rx="2" />
        <rect class="pl-fur pl-fade" pathLength="1" x="327" y="216" width="22" height="15" rx="2" />
        <rect class="pl-fur pl-fade" pathLength="1" x="281" y="291" width="22" height="15" rx="2" />
        <rect class="pl-fur pl-fade" pathLength="1" x="327" y="291" width="22" height="15" rx="2" />

        <!-- dormitorio: cama pegada a la cabecera + almohadas + mesas de luz + cómoda -->
        <rect class="pl-fur pl-fade" pathLength="1" x="506" y="154" width="86" height="104" rx="4" />
        <rect class="pl-fur pl-fade" pathLength="1" x="512" y="158" width="34" height="18" rx="3" />
        <rect class="pl-fur pl-fade" pathLength="1" x="552" y="158" width="34" height="18" rx="3" />
        <path class="pl-fur pl-fade" pathLength="1" d="M506 208 H592" />
        <rect class="pl-fur pl-fade" pathLength="1" x="480" y="154" width="22" height="22" />
        <rect class="pl-fur pl-fade" pathLength="1" x="596" y="154" width="20" height="22" />
        <rect class="pl-fur pl-fade" pathLength="1" x="435" y="217" width="26" height="74" />
        <path class="pl-fur pl-fade" pathLength="1" d="M448 217 V291" />

        <!-- baño (más compacto): ducha en el rincón · inodoro a la izq., lavabo bajo la ducha -->
        <rect class="pl-fur pl-fade" pathLength="1" x="568" y="315" width="54" height="42" />
        <path class="pl-fur pl-fade" pathLength="1" d="M568 315 L622 357" />
        <circle class="pl-fur pl-fade" pathLength="1" cx="595" cy="336" r="3" />
        <rect class="pl-fur pl-fade" pathLength="1" x="488" y="389" width="26" height="10" rx="2" />
        <ellipse class="pl-fur pl-fade" pathLength="1" cx="501" cy="381" rx="11" ry="8" />
        <rect class="pl-fur pl-fade" pathLength="1" x="544" y="388" width="42" height="12" rx="3" />
        <ellipse class="pl-fur pl-fade" pathLength="1" cx="565" cy="394" rx="13" ry="6" />
      </g>

      <!-- ===================== FASE 4 · GRAFISMO (COTA · ESCALA) ===================== -->
      <!-- opacidad tenue a nivel de grupo (no en cada elemento): así `.pl-fade`
           oculta los números hasta su turno y no aparecen al inicio -->
      <g data-ph="4" class="pl-graf">
        <!-- cota general de ancho y de alto: se dibujan EN PARALELO (mismo delay
             por índice vía data-step, ver script) — referencias → línea → marcas
             → número, y recién cuando terminan ambas entra la escala -->
        <path class="pl-dim pl-draw" data-step="0" pathLength="1" d="M162 136 V104" />
        <path class="pl-dim pl-draw" data-step="1" pathLength="1" d="M638 136 V104" />
        <path class="pl-dim pl-draw" data-step="2" pathLength="1" d="M162 110 H638" />
        <path class="pl-dim pl-draw" data-step="3" pathLength="1" d="M158 114 l8 -8" />
        <path class="pl-dim pl-draw" data-step="4" pathLength="1" d="M634 114 l8 -8" />
        <text class="pl-t pl-fade" data-step="5" x="400" y="105" font-size="12" text-anchor="middle">8.80</text>

        <!-- cota general de alto (izquierda) -->
        <path class="pl-dim pl-draw" data-step="0" pathLength="1" d="M160 138 H140" />
        <path class="pl-dim pl-draw" data-step="1" pathLength="1" d="M160 412 H140" />
        <path class="pl-dim pl-draw" data-step="2" pathLength="1" d="M146 138 V412" />
        <path class="pl-dim pl-draw" data-step="3" pathLength="1" d="M142 142 l8 -8" />
        <path class="pl-dim pl-draw" data-step="4" pathLength="1" d="M142 416 l8 -8" />
        <text class="pl-t pl-fade" data-step="5" x="139" y="275" font-size="11" text-anchor="middle" transform="rotate(-90 139 275)">5.10</text>

        <!-- escala gráfica (abajo izquierda) -->
        <path class="pl-dim pl-draw" pathLength="1" d="M162 442 H250" />
        <path class="pl-dim pl-draw" pathLength="1" d="M162 442 V449 M184 442 V449 M206 442 V449 M228 442 V449 M250 442 V449" />
        <text class="pl-t pl-fade" x="162" y="461" font-size="8.5" text-anchor="middle">0</text>
        <text class="pl-t pl-fade" x="206" y="461" font-size="8.5" text-anchor="middle">2</text>
        <text class="pl-t pl-fade" x="250" y="461" font-size="8.5" text-anchor="middle">4</text>
        <text class="pl-t pl-fade" x="262" y="461" font-size="8.5" text-anchor="start">m</text>
      </g>
    </svg>
  </div>

  <!-- indicador de carga: barra inferior que se completa + porcentaje mono -->
  <div class="pl-loader" aria-hidden="true">
    <div class="pl-loader-top">
      <span class="pl-loader-label">Cargando</span>
      <span class="pl-loader-pct" data-pct>0%</span>
    </div>
    <div class="pl-bar"><span class="pl-bar-fill"></span></div>
  </div>
</div>

<noscript><style>.preloader{display:none !important}</style></noscript>

<script is:inline>
  (function () {
    try {
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // ¿ya se mostró en esta sesión? → saltar directo al hero, sin flash ni
      // lock. El flag lo escribe el módulo de abajo cuando arranca el dibujo,
      // así que acá SÓLO se lee (si lo seteáramos acá, el módulo lo leería
      // como "ya visto" y nunca se dibujaría en la primera carga).
      var seen = false;
      try { seen = sessionStorage.getItem('e21-preloaded') === '1'; } catch (e) {}
      var p0 = document.getElementById('preloader');
      if (seen) {
        if (p0) p0.style.display = 'none';
        return;
      }
      var r = document.documentElement;
      r.classList.add('pl-lock');
      // salvavidas: si el módulo no corriera (error de bundle), nunca dejar
      // el scroll bloqueado ni el overlay pegado.
      setTimeout(function () {
        r.classList.remove('pl-lock');
        var p = document.getElementById('preloader');
        if (p && !p.classList.contains('is-drawing') && !p.classList.contains('is-done')) {
          p.style.display = 'none';
        }
      }, 8000);
    } catch (e) {}
  })();
</script>

<script>
  const pre = document.getElementById('preloader');
  const root = document.documentElement;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ¿ya se mostró en esta sesión del navegador? (el inline boot de arriba ya lo
  // ocultó sin flash; acá lo confirmamos para no correr el dibujo).
  let seen = false;
  try {
    seen = sessionStorage.getItem('e21-preloaded') === '1';
  } catch (e) {
    /* storage no disponible → mostrar igual */
  }

  if (pre) {
    if (reduce || seen) {
      root.classList.remove('pl-lock');
      pre.remove();
    } else {
      // marcar que ya se mostró: los reloads y el link "Inicio" (→ recarga `/`)
      // dentro de esta sesión lo saltean y van directo al hero.
      try {
        sessionStorage.setItem('e21-preloaded', '1');
      } catch (e) {
        /* ignore */
      }

      const STROKE = 0.7; // duración de cada trazo (debe coincidir con pl-stroke en preloader.css)
      const HOLD = 0.35; // pausa con el plano completo antes de la barrida
      const TRANS = 1.25; // duración de la barrida hacia arriba (revela el hero)

      // delays por fase (stagger entre trazos): dibujo pausado, más deliberado en
      // el contorno y el grafismo, más fluido en tabiques y mobiliario
      const step: Record<string, number> = { '1': 0.22, '2': 0.042, '3': 0.026, '4': 0.075 };
      const gap = 0.22; // pausa entre fases (se percibe capa por capa)

      // Elementos con el mismo data-step (dentro de la misma fase) se agrupan y
      // comparten delay: así la cota de ancho y la de alto se dibujan en paralelo
      // (índice a índice) y recién al terminar ambas entra la escala.
      const els = Array.from(pre.querySelectorAll<SVGElement>('.pl-draw, .pl-fade'));
      type Grupo = { ph: string; els: SVGElement[] };
      const grupos: Grupo[] = [];
      const indice = new Map<string, number>();
      let uid = 0;
      for (const el of els) {
        const ph = el.closest('[data-ph]')?.getAttribute('data-ph') ?? '1';
        const sync = el.getAttribute('data-step');
        const key = ph + (sync !== null ? ':s' + sync : ':u' + uid++);
        let idx = indice.get(key);
        if (idx === undefined) {
          idx = grupos.length;
          indice.set(key, idx);
          grupos.push({ ph, els: [] });
        }
        grupos[idx].els.push(el);
      }

      let t = 0.06;
      let prev = '';
      let maxDelay = 0;
      for (const g of grupos) {
        if (prev && g.ph !== prev) t += gap;
        prev = g.ph;
        for (const el of g.els) el.style.animationDelay = t.toFixed(3) + 's';
        maxDelay = t;
        t += step[g.ph] ?? 0.02;
      }

      const drawEnd = maxDelay + STROKE;

      let done = false;
      let completing = false;
      let dismissTimer = 0;
      let transTimer = 0;
      let safetyTimer = 0;

      // cierre: quita el overlay (ya barrido hacia arriba) dejando el hero real
      // en cuadro — el "21" que venía girando en 3D detrás
      const finish = () => {
        if (done) return;
        done = true;
        clearTimeout(dismissTimer);
        clearTimeout(transTimer);
        clearTimeout(safetyTimer);
        pre.classList.add('is-done');
        root.classList.remove('pl-lock');
        const remove = () => pre.remove();
        pre.addEventListener('transitionend', remove, { once: true });
        setTimeout(remove, 1400);
      };

      // transición plano → hero: todo el overlay se barre hacia arriba como un
      // telón, revelando el "21" del hero (ya girando en 3D); tras `TRANS` se
      // quita el overlay ya invisible.
      const complete = () => {
        if (done || completing) return;
        completing = true;
        pre.classList.add('is-transition');
        transTimer = window.setTimeout(finish, TRANS * 1000);
      };

      let started = false;
      const run = () => {
        if (started || done) return;
        started = true;
        pre.classList.add('is-drawing');

        // indicador de carga: la barra se llena en `drawEnd` (mismo tiempo que
        // tarda el trazado) y el porcentaje mono cuenta 0→100 en paralelo.
        pre.style.setProperty('--pl-load', drawEnd.toFixed(2) + 's');
        const pctEl = pre.querySelector('[data-pct]');
        if (pctEl) {
          const loadMs = drawEnd * 1000;
          let startTs = 0;
          const tick = (now: number) => {
            if (done || completing) {
              pctEl.textContent = '100%';
              return;
            }
            if (!startTs) startTs = now;
            const p = Math.min(100, Math.round(((now - startTs) / loadMs) * 100));
            pctEl.textContent = p + '%';
            if (p < 100) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }

        // al completar el dibujo: hold con el plano y después la barrida hacia arriba
        dismissTimer = window.setTimeout(complete, (drawEnd + HOLD) * 1000);
        safetyTimer = window.setTimeout(finish, (drawEnd + HOLD + TRANS) * 1000 + 3000);
      };

      // Si la pestaña carga en segundo plano, rAF/animaciones están pausadas:
      // esperamos a que sea visible para que nadie se pierda el trazado.
      if (document.hidden) {
        const onVis = () => {
          if (!document.hidden) {
            document.removeEventListener('visibilitychange', onVis);
            run();
          }
        };
        document.addEventListener('visibilitychange', onVis);
      } else {
        run();
      }

      // saltar con cualquier interacción
      const skip = () => finish();
      ['pointerdown', 'keydown', 'wheel', 'touchstart'].forEach((ev) =>
        window.addEventListener(ev, skip, { once: true, passive: true }),
      );
    }
  }
</script>
