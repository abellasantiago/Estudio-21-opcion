---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getPortada } from '../lib/images';

interface Props {
  proyecto: CollectionEntry<'proyectos'>;
  /** delay del reveal (1..3) */
  d?: number;
}

const { proyecto, d = 1 } = Astro.props;
const { nombre, codigo, slug, estado, ubicacion, anio } = proyecto.data;
const portada = getPortada(slug);
const estadoLabel = estado === 'en-proceso' ? 'En proceso' : 'Terminado';
---

<a
  class="card reveal"
  data-d={d}
  data-status={estado}
  href={`/proyectos/${slug}/`}
  aria-label={`${nombre} — ver proyecto`}
>
  {portada ? (
    <div class="thumb">
      <Picture
        src={portada}
        formats={['avif', 'webp']}
        alt={`Portada del proyecto ${nombre}`}
        widths={[400, 600, 800]}
        sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 360px"
        loading="lazy"
      />
      <span class="code-tag">{codigo}</span>
    </div>
  ) : (
    <div class="thumb is-placeholder">
      <span class="code">{codigo}</span>
      <span class="ph">imagen pendiente</span>
    </div>
  )}
  <div class="meta">
    <div class="name">{nombre}</div>
    <div class="sub">
      <span>{ubicacion} · {anio}</span>
      <span class={`status ${estado}`}><span class="pip"></span>{estadoLabel}</span>
    </div>
  </div>
</a>
