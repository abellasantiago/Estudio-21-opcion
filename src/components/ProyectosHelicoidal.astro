---
/*
 * ProyectosHelicoidal — sección de proyectos como carrusel helicoidal 3D.
 *
 * Las cards se distribuyen en un cilindro 3D que rota alrededor de un eje
 * vertical y desciende a medida que se scrollea la sección (sticky scrubbing),
 * dando la sensación de bajar por una espiral. Escala y opacidad se interpolan
 * con una curva de coseno según el ángulo de cada card respecto al frente.
 *
 * Capas:
 *   1. Markup semántico: lista real de proyectos como links (accesible, SSR).
 *   2. CSS 3D: el efecto es una capa de presentación encima de esa lista.
 *   3. Fallback: sin JS o con prefers-reduced-motion queda una grilla accesible.
 */
import '../styles/proyectos-helicoidal.css';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPortada } from '../lib/images';

// Orden editorial: primero lo activo hoy (en proceso), después el track record
// (terminados) y al final lo que viene (próximamente). Dentro de cada grupo,
// por año descendente. Independiente del orden en la content collection.
const ordenEstado = { 'en-proceso': 0, terminado: 1, proximamente: 2 } as const;

const proyectos = await getCollection('proyectos');
proyectos.sort((a, b) => {
  const ea = ordenEstado[a.data.estado];
  const eb = ordenEstado[b.data.estado];
  if (ea !== eb) return ea - eb;
  return b.data.anio - a.data.anio;
});

const estadoLabels = {
  proximamente: 'Próximamente',
  'en-proceso': 'En proceso',
  terminado: 'Terminado',
} as const;

const items = proyectos.map((p) => ({ ...p.data, portada: getPortada(p.data.slug) }));
const total = items.length;
const pad = (n: number) => String(n).padStart(2, '0');
---

<section class="ph block" id="proyectos" style={`--ph-total:${total}`} aria-labelledby="ph-title">
  <div class="wrap ph-head">
    <div class="ph-head-top">
      <div class="sec-head ph-sechead">
        <span class="eyebrow reveal">Obra construida</span>
        <h2 id="ph-title" class="section-title reveal" data-d="1">
          Quince proyectos, una misma manera de hacer.
        </h2>
      </div>

      <!-- Cambia entre el cilindro (recorrido) y la grilla (ver todo de un vistazo).
           Oculto por defecto; el <script> lo habilita sólo cuando el 3D está activo
           (con motion permitido). En 3D se relocaliza pineado en el panel sticky. -->
      <button
        type="button"
        class="ph-viewtoggle"
        id="phViewToggle"
        aria-pressed="false"
        aria-label="Ver todos los proyectos en una grilla"
      >
        <svg class="ph-vt-ico ico-grid" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <rect x="1.5" y="1.5" width="5.3" height="5.3" rx="1" /><rect x="9.2" y="1.5" width="5.3" height="5.3" rx="1" />
          <rect x="1.5" y="9.2" width="5.3" height="5.3" rx="1" /><rect x="9.2" y="9.2" width="5.3" height="5.3" rx="1" />
        </svg>
        <svg class="ph-vt-ico ico-spin" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.8 8a5.8 5.8 0 1 1-1.75-4.15" /><path d="M12.7 1.5v3h-3" />
        </svg>
        <span class="ph-vt-txt">Ver todos</span>
      </button>
    </div>

    <div class="ph-bar reveal" data-d="2">
      <div class="filters" id="phFilters" role="group" aria-label="Filtrar proyectos por estado">
        <button type="button" data-filter="todos" aria-pressed="true">Todos</button>
        <button type="button" data-filter="en-proceso" aria-pressed="false">En proceso</button>
        <button type="button" data-filter="proximamente" aria-pressed="false">Próximamente</button>
        <button type="button" data-filter="terminado" aria-pressed="false">Terminados</button>
      </div>
      <p class="ph-counter" aria-hidden="true">
        <span class="ph-num" data-ph-current>01</span>
        <span class="ph-sep">/</span>
        <span class="ph-num" data-ph-total>{pad(total)}</span>
      </p>
    </div>
  </div>

  <div class="ph-sticky">
    <span class="ghost21" aria-hidden="true">21</span>
    <span class="marks" aria-hidden="true">
      <span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span>
    </span>

    <div class="wrap ph-shell">
      <div class="ph-stage">
        <ul class="ph-axis" id="phAxis">
          {items.map((it, i) => (
            <li class="ph-card" data-status={it.estado} data-index={i}>
              <a class="ph-link" href={`/proyectos/${it.slug}/`} aria-label={`${it.nombre} — ver proyecto`}>
                <span class="ph-thumb">
                  {it.portada ? (
                    <Image
                      src={it.portada}
                      alt={`Portada del proyecto ${it.nombre}`}
                      widths={[400, 600, 820, 1080]}
                      sizes="(max-width: 680px) 320px, 440px"
                      quality={88}
                      loading={i < 3 ? 'eager' : 'lazy'}
                    />
                  ) : (
                    <span class="ph-ph">imagen pendiente</span>
                  )}
                  <span class="ph-cta" aria-hidden="true">Ver proyecto →</span>
                </span>
                <span class="ph-meta">
                  <span class="ph-name">{it.nombre}</span>
                  <span class="ph-sub">
                    <span class="ph-loc">{it.barrio ?? it.ubicacion} · {it.anio}{it.unidades != null ? ` · ${it.unidades} unidades` : ''}</span>
                    <span class={`status ${it.estado}`}><span class="pip"></span>{estadoLabels[it.estado]}</span>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <p class="ph-hint" aria-hidden="true">Scrolleá para recorrer la obra</p>
    </div>
  </div>
</section>

<script>
  // Toda la lógica corre client-side. El markup base (lista de proyectos)
  // ya funciona sin JS; acá sólo se agrega la capa 3D si hay motion permitido.
  type CardRef = { el: HTMLElement; status: string; baseAngle: number };

  const section = document.getElementById('proyectos');
  if (section && section.classList.contains('ph')) {
    const axis = section.querySelector<HTMLElement>('#phAxis');
    const cardEls = Array.from(section.querySelectorAll<HTMLElement>('.ph-card'));
    const filterBtns = Array.from(section.querySelectorAll<HTMLButtonElement>('#phFilters button'));
    const counterCur = section.querySelector<HTMLElement>('[data-ph-current]');
    const counterTot = section.querySelector<HTMLElement>('[data-ph-total]');
    // capas de fondo del panel sticky que reciben parallax vertical a distintas
    // velocidades (multicapa = sensación de profundidad). El header
    // (título/filtros/contador) ya no está acá: vive fuera del sticky y scrollea.
    const ghost21 = section.querySelector<HTMLElement>('.ghost21');
    const marksEl = section.querySelector<HTMLElement>('.marks');
    // barra de filtros: en 3D se relocaliza al panel sticky (riel pineado); en
    // grilla/fallback se queda en el header. Guardamos su lugar original.
    const bar = section.querySelector<HTMLElement>('.ph-bar');
    const sticky = section.querySelector<HTMLElement>('.ph-sticky');
    const barHome = bar?.parentElement ?? null;
    // toggle de vista (cilindro ⇄ grilla). Su "casa" es el header; en 3D el
    // script lo relocaliza dentro del panel sticky (queda pineado).
    const toggleBtn = section.querySelector<HTMLButtonElement>('#phViewToggle');
    const toggleTxt = toggleBtn?.querySelector<HTMLElement>('.ph-vt-txt') ?? null;
    const toggleHome = toggleBtn?.parentElement ?? null;
    const header = document.getElementById('header');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    // ---- parámetros ----
    const VERT_STEP = 64; // descenso vertical por proyecto (px) — aire entre cards
    const MAX_STEP = 34; // ° máx entre cards: con pocos proyectos (filtros) no quedan ralos
    // ---- zoom al centro (pico 1.60×) ----
    // Con 15 cards juntas (24° entre sí) el zoom tiene que ser PUNTUAL: sólo la
    // central crece, las vecinas se quedan en su tamaño de viaje → no se pisan.
    const BASE_SIDE = 0.46; // tamaño "de viaje" en laterales/dorso (chico = no se superponen)
    const BASE_FRONT = 0.86; // tamaño base al frente, sin el zoom
    const ZOOM_AMOUNT = 0.84; // extra al centro → pico = BASE_FRONT + ZOOM_AMOUNT = 1.70×
    const ZOOM_WIDTH = 22; // ° a cada lado del centro donde actúa el zoom (angosto = pop aislado)
    const SS = 2; // factor de supersample: la card se maqueta a SS× (CSS) y acá se reduce ÷SS → nítida
    let RADIUS = 440; // radio del cilindro (px) — círculo amplio = cards más separadas; se ajusta en mobile
    let stepAngle = 0; // ° entre cards (compartido layout/render); lo fija layout()
    // px que scrollea la sección ANTES de que el panel sticky se fije (= alto del
    // header con el título). Hasta ese punto el scroll mueve la página, no el
    // helicoidal: el progreso queda en 0 y la 1ª card se mantiene centrada.
    let headOffset = 0;

    const cards: CardRef[] = cardEls.map((el) => ({
      el,
      status: el.dataset.status ?? '',
      baseAngle: 0,
    }));
    let active: CardRef[] = cards; // subconjunto visible según el filtro
    let N = active.length;

    let scroll = 0;
    let targetScroll = 0;
    let lastActiveIdx = -1;
    let running = false;
    let rafId = 0;

    // ---- estado de la vista (cilindro 3D ⇄ grilla "ver todos") ----
    // 'cilindro' = helicoidal atado al scroll · 'grilla' = todos a la vista.
    let viewMode: 'cilindro' | 'grilla' = 'cilindro';
    let transitioning = false; // true mientras corre el desenrollado/reensamblado
    let flipTimer = 0;
    const is3d = () => section!.classList.contains('is-3d');
    const navH = () => header?.getBoundingClientRect().height || 58;
    // easing del viaje de las cards: entrada decidida, aterrizaje suave.
    const FLIP_EASE = 'cubic-bezier(.22,.72,.14,1)';

    const clamp = (v: number, a: number, b: number) => Math.min(b, Math.max(a, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const pad = (n: number) => String(n).padStart(2, '0');
    const calcRadius = () => (window.innerWidth < 680 ? 300 : 540);

    // ---- posicionar el cilindro para el subconjunto visible ----
    function layout() {
      RADIUS = calcRadius();
      N = active.length;
      // El panel sticky (top:0) se fija cuando su borde superior —en flujo normal,
      // a `sticky.offsetTop` px del tope de la sección— llega al tope del viewport.
      // No depende de N; sí del alto del header (responsive) → se recalcula acá.
      headOffset = sticky ? sticky.offsetTop : 0;
      // ° entre cards: 360/N reparte en todo el cilindro, pero con pocos
      // proyectos (al filtrar) eso los deja ralos → lo topamos a MAX_STEP para
      // que queden juntos en un arco frontal en vez de desperdigados.
      stepAngle = Math.min(360 / Math.max(N, 1), MAX_STEP);
      active.forEach((c, i) => {
        c.baseAngle = i * stepAngle; // ángulo fijo de la card en el cilindro
        c.el.style.top = `${VERT_STEP * i}px`; // slot vertical en la espiral
      });
      section!.style.setProperty('--ph-total', String(Math.max(N, 1)));
      if (counterTot) counterTot.textContent = pad(Math.max(N, 1));
    }

    // ---- progreso de scroll de la sección (0..1) -> targetScroll (0..N-1) ----
    function updateTarget() {
      if (!is3d() || transitioning) return; // en grilla / durante el flip no se scrubea
      const passed = -section!.getBoundingClientRect().top;
      // El recorrido del helicoidal arranca cuando el panel se fija (passed >=
      // headOffset) y termina al soltarse (passed = offsetHeight - innerHeight).
      // Antes de fijarse el progreso es 0 → la 1ª card queda centrada mientras la
      // sección sube; el giro sólo empieza en el tramo pineado.
      const range = section!.offsetHeight - window.innerHeight - headOffset;
      const progress = range > 0 ? clamp((passed - headOffset) / range, 0, 1) : 0;
      // Sin snap: targetScroll sigue el progreso exacto del scroll → el cilindro
      // queda donde lo dejaste, sin re-centrarse solo (más fluido al recorrer).
      targetScroll = progress * Math.max(N - 1, 0);
      section!.classList.toggle('is-scrolling', progress > 0.01);
    }

    // ---- render: escala/opacidad continuas por curva de coseno ----
    function render() {
      const step = stepAngle;
      const rotY = -scroll * step;
      const transY = -scroll * VERT_STEP;
      if (axis) axis.style.transform = `rotateY(${rotY}deg) translateY(${transY}px)`;

      // Parallax MULTICAPA: el cilindro baja scroll*VERT_STEP px; las capas de
      // fondo suben a fracciones distintas de esa velocidad → cada una a su
      // "profundidad" (fantasma lejos/lento, marcas medio).
      const bgParallax = scroll * VERT_STEP * 0.35;
      if (ghost21) ghost21.style.transform = `translateY(${-bgParallax * 0.55}px)`;
      if (marksEl) marksEl.style.transform = `translateY(${-bgParallax * 0.85}px)`;

      active.forEach((c) => {
        const eff = (((c.baseAngle + rotY) % 360) + 360) % 360; // ángulo efectivo (0 = frente)
        const fromFront = eff > 180 ? 360 - eff : eff; // 0=frente, 180=dorso
        const cosT = (Math.cos((fromFront * Math.PI) / 180) + 1) / 2; // 1 frente, 0 dorso
        // Tamaño "de viaje": chico en laterales, base al frente (curva de profundidad).
        const depth = BASE_SIDE + (BASE_FRONT - BASE_SIDE) * Math.pow(cosT, 1.3);
        // Zoom al centro: pico justo al frente, baja suave a cada lado y es nulo
        // más allá de ZOOM_WIDTH°. La card entra, crece hasta ~1.60× en el centro
        // y se deszoomea al seguir su curso (entra y sale igual, sin saltos).
        const peak = fromFront < ZOOM_WIDTH ? (Math.cos((fromFront / ZOOM_WIDTH) * Math.PI) + 1) / 2 : 0;
        const scale = depth + ZOOM_AMOUNT * peak;
        // opacidad con falloff marcado: las laterales pierden visibilidad.
        const opacity = 0.12 + 0.88 * Math.pow(cosT, 2.2);
        // difuminado sólo en laterales/dorso (la central y vecinas quedan nítidas).
        const blur = (1 - cosT) * 1.8;
        c.el.style.opacity = opacity.toFixed(3);
        c.el.style.filter = blur > 0.25 ? `blur(${blur.toFixed(2)}px)` : 'none';
        // ÷SS: compensa la maqueta a SS× → tamaño visual idéntico, textura nítida
        c.el.style.transform = `rotateY(${c.baseAngle}deg) translateZ(${RADIUS}px) scale(${(scale / SS).toFixed(4)})`;
        c.el.style.pointerEvents = cosT > 0.55 ? 'auto' : 'none'; // no clickear lo que no se ve
        c.el.classList.toggle('is-front', cosT > 0.92); // revela la info extra (vía CSS)
      });

      const idx = N ? ((Math.round(scroll) % N) + N) % N : 0;
      if (idx !== lastActiveIdx) {
        active.forEach((c, i) => c.el.classList.toggle('is-active', i === idx));
        if (counterCur) counterCur.textContent = pad(idx + 1);
        lastActiveIdx = idx;
      }
    }

    function tick() {
      scroll = lerp(scroll, targetScroll, 0.1);
      if (Math.abs(scroll - targetScroll) < 0.001) scroll = targetScroll;
      render();
    }
    function loop() {
      if (!running) return;
      tick();
      rafId = requestAnimationFrame(loop);
    }
    const start = () => { if (!running) { running = true; loop(); } };
    const stop = () => { running = false; cancelAnimationFrame(rafId); };

    // ---- traer una card al frente desplazando la página (foco por teclado) ----
    function scrollToIndex(i: number) {
      // Mapea la card i al tramo pineado [headOffset .. offsetHeight-innerHeight]
      // (mismo modelo que updateTarget): i=0 cae en el arranque del helicoidal.
      const range = section!.offsetHeight - window.innerHeight - headOffset;
      const p = N > 1 ? i / (N - 1) : 0;
      window.scrollTo({
        top: section!.offsetTop + headOffset + p * range,
        behavior: reduce.matches ? 'auto' : 'smooth',
      });
    }

    // ---- filtros (sirven igual en 3D y en grilla) ----
    function applyFilter(filter: string) {
      if (transitioning) return; // no filtrar a mitad del desenrollado/reensamblado
      filterBtns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.filter === filter)));
      active = cards.filter((c) => filter === 'todos' || c.status === filter);
      cards.forEach((c) => {
        const show = active.includes(c);
        c.el.style.display = show ? '' : 'none';
        if (!show) c.el.classList.remove('is-active');
      });
      if (section!.classList.contains('is-3d')) {
        lastActiveIdx = -1;
        // Alto del NUEVO recorrido según --ph-total = N (ver min-height en el CSS:
        // 100vh + (N-1)·--ph-scroll). Lo calculamos ANTES de reconstruir, para
        // decidir sin depender del reflow.
        const rawStep = getComputedStyle(section!).getPropertyValue('--ph-scroll').trim();
        const phStep = rawStep.endsWith('vh')
          ? (parseFloat(rawStep) / 100) * window.innerHeight
          : parseFloat(rawStep) || 0;
        const newScrollable = Math.max(active.length - 1, 0) * phStep;
        if (window.scrollY > section!.offsetTop + newScrollable) {
          // Vas a un filtro más corto y tu posición quedaría más allá de su final
          // (te dejaría clavado en la última card). Saltamos al inicio PRIMERO
          // —instantáneo, con la sección todavía alta = destino válido— y RECIÉN
          // LUEGO reconstruimos el cilindro más corto: al acortarse ya estás
          // arriba, el recorte pasa por debajo del viewport y nunca se ve el final
          // de la sección (sin el flash ni el giro de rebote).
          // OJO: 'instant', NO 'auto'. `html` tiene `scroll-behavior: smooth`, y
          // behavior:'auto' RESPETA ese valor → animaría suave (el "glitch" de
          // pasar por el medio). 'instant' fuerza el salto sin animación.
          // Aterriza en el ARRANQUE del helicoidal (offsetTop + headOffset), no en
          // el tope de la sección: caés justo donde el scroll empieza a mover las
          // cards, con la 1ª centrada.
          window.scrollTo({ top: section!.offsetTop + headOffset, behavior: 'instant' });
          layout();
          scroll = 0;
          targetScroll = 0;
        } else {
          // Cabés dentro del nuevo recorrido: se mantiene tu posición y se remapea
          // el progreso 0..1 al nuevo N (las cards cambian sin saltar).
          layout();
          updateTarget();
          scroll = targetScroll;
        }
        render();
      } else {
        N = active.length;
        if (counterTot) counterTot.textContent = pad(Math.max(N, 1));
      }
    }

    filterBtns.forEach((b) =>
      b.addEventListener('click', () => applyFilter(b.dataset.filter ?? 'todos')),
    );

    // ---- relocar barra de filtros + toggle según el modo ----------------------
    // En 3D ambos viven pineados en el panel sticky; en grilla vuelven al header.
    function dockControls(to3d: boolean) {
      if (to3d) {
        if (bar && sticky && bar.parentElement !== sticky) {
          bar.classList.remove('reveal'); // el reveal pelearía con el transform del riel
          sticky.appendChild(bar);
        }
        if (toggleBtn && sticky && toggleBtn.parentElement !== sticky) sticky.appendChild(toggleBtn);
      } else {
        if (bar && barHome && bar.parentElement !== barHome) barHome.appendChild(bar);
        if (toggleBtn && toggleHome && toggleBtn.parentElement !== toggleHome) {
          toggleHome.appendChild(toggleBtn);
        }
      }
    }

    // ---- borrar los estilos inline del cilindro → deja actuar a la grilla CSS ----
    // Sobre TODAS las cards (no sólo las visibles): si una está filtrada afuera y
    // luego se vuelve a mostrar, no debe arrastrar transform/opacidad del cilindro.
    function clearCylinderStyles() {
      if (axis) axis.style.transform = '';
      [ghost21, marksEl].forEach((el) => { if (el) el.style.transform = ''; });
      cards.forEach((c) => {
        c.el.style.transform = '';
        c.el.style.opacity = '';
        c.el.style.filter = '';
        c.el.style.top = '';
        c.el.style.pointerEvents = '';
        c.el.classList.remove('is-active', 'is-front');
      });
    }

    // ---- reflejar el modo en el botón (texto/estado/accesibilidad) ----
    function syncToggle() {
      if (!toggleBtn) return;
      const grilla = viewMode === 'grilla';
      toggleBtn.setAttribute('aria-pressed', String(grilla));
      toggleBtn.classList.toggle('is-grid', grilla);
      if (toggleTxt) toggleTxt.textContent = grilla ? 'Volver al giro' : 'Ver todos';
      toggleBtn.setAttribute(
        'aria-label',
        grilla
          ? 'Volver a la vista giratoria de proyectos'
          : 'Ver todos los proyectos en una grilla',
      );
    }

    // ---- FLIP: rects de las cards visibles en coordenadas de viewport ----
    const rectsOf = () => active.map((c) => c.el.getBoundingClientRect());

    // limpieza común al terminar una transición (libera transiciones inline)
    function finishFlip(total: number, after?: () => void) {
      clearTimeout(flipTimer);
      flipTimer = window.setTimeout(() => {
        active.forEach((c) => {
          c.el.style.transition = '';
          c.el.style.transformOrigin = '';
        });
        section!.classList.remove('is-flipping');
        transitioning = false;
        after?.();
      }, total);
    }

    // ======= DESENROLLAR: cilindro → grilla (cada card viaja a su celda) =======
    function goGrilla() {
      if (transitioning || viewMode === 'grilla') return;
      transitioning = true;
      viewMode = 'grilla';
      syncToggle();
      stop();

      // FIRST — posición y opacidad actuales de cada card sobre el cilindro
      const first = rectsOf();
      const firstOpac = active.map((c) => getComputedStyle(c.el).opacity);

      // pasar al layout de grilla (documento normal, scrolleable)
      section!.classList.remove('is-3d', 'is-scrolling');
      section!.classList.add('is-grid', 'is-flipping');
      dockControls(false);
      clearCylinderStyles();

      // encuadrar la grilla justo bajo el navbar. Salto SECO: `html` tiene
      // scroll-behavior:smooth y 'auto' lo respetaría (animaría) → 'instant'.
      const top = Math.max(0, section!.offsetTop - navH() - 4);
      window.scrollTo({ top, behavior: 'instant' as ScrollBehavior });

      // LAST — destino de cada card ya en la grilla
      const last = rectsOf();

      // INVERT — devolver cada card a su lugar del cilindro (delta de centros)
      active.forEach((c, i) => {
        const f = first[i], l = last[i];
        const dx = f.left + f.width / 2 - (l.left + l.width / 2);
        const dy = f.top + f.height / 2 - (l.top + l.height / 2);
        // escala de partida = tamaño en pantalla ÷ tamaño en la celda. Se topa por
        // abajo: las cards del dorso están tan escorzadas (rect casi 0) que sin el
        // piso arrancarían como un punto; con el piso nacen chicas y crecen limpio.
        const rawS = f.width > 4 && l.width > 4 ? f.width / l.width : 1;
        const s = Math.max(0.25, Math.min(2.6, rawS));
        c.el.style.transition = 'none';
        c.el.style.transformOrigin = '50% 50%';
        c.el.style.opacity = firstOpac[i];
        c.el.style.transform = `translate(${dx.toFixed(1)}px,${dy.toFixed(1)}px) scale(${s.toFixed(3)})`;
      });

      void section!.offsetWidth; // reflow: consolida el estado invertido

      // PLAY — soltar a la celda con una cascada leve por índice
      const DUR = 720;
      active.forEach((c, i) => {
        const delay = i * 24;
        c.el.style.transition =
          `transform ${DUR}ms ${FLIP_EASE} ${delay}ms, opacity ${Math.round(DUR * 0.7)}ms ease ${delay}ms`;
        c.el.style.transform = '';
        c.el.style.opacity = '';
      });

      finishFlip(DUR + active.length * 24 + 80);
    }

    // ======= REENSAMBLAR: grilla → cilindro (las cards florecen en su anillo) =======
    function goCilindro() {
      if (transitioning || viewMode === 'cilindro') return;
      transitioning = true;
      viewMode = 'cilindro';
      syncToggle();

      // montar el cilindro en el arranque del helicoidal (eje SIN rotar → el
      // transform base de cada card queda alineado ~pantalla para el "bloom")
      section!.classList.remove('is-grid');
      section!.classList.add('is-3d', 'is-flipping');
      dockControls(true);
      layout();
      headOffset = sticky ? sticky.offsetTop : 0;
      scroll = 0;
      targetScroll = 0;
      lastActiveIdx = -1;
      render(); // deja a cada card en su transform/opacidad final del cilindro

      // encuadrar el panel pineado (salto seco, ver nota de scroll arriba)
      window.scrollTo({ top: section!.offsetTop + headOffset, behavior: 'instant' as ScrollBehavior });

      // estado final por card (destino del bloom) capturado del render anterior
      const bases = active.map((c) => c.el.style.transform);
      const opac = active.map((c) => c.el.style.opacity || '1');

      active.forEach((c, i) => {
        c.el.style.transition = 'none';
        c.el.style.transformOrigin = '50% 50%';
        c.el.style.opacity = '0';
        c.el.style.transform = `scale(.62) ${bases[i]}`; // arranca chico, en su lugar del anillo
      });

      void section!.offsetWidth;

      const DUR = 640;
      active.forEach((c, i) => {
        const delay = i * 20;
        c.el.style.transition =
          `transform ${DUR}ms ${FLIP_EASE} ${delay}ms, opacity ${Math.round(DUR * 0.85)}ms ease ${delay}ms`;
        c.el.style.transform = bases[i];
        c.el.style.opacity = opac[i];
      });

      finishFlip(DUR + active.length * 20 + 90, () => {
        // reanudar el scrubbing desde el arranque (rAF vuelve a mandar el transform)
        active.forEach((c) => (c.el.style.transition = ''));
        updateTarget();
        scroll = targetScroll;
        lastActiveIdx = -1;
        render();
        start();
      });
    }

    // ---- montar el cilindro sin animación (carga inicial / cambio de preferencia) ----
    function enter3DInitial() {
      section!.classList.remove('is-grid');
      section!.classList.add('is-3d');
      dockControls(true);
      layout();
      updateTarget();
      lastActiveIdx = -1;
      render();
      start();
    }

    // ---- interacciones (se enganchan UNA vez; cada handler se guarda por modo) ----
    const io = new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          if (e.isIntersecting && is3d() && !transitioning) start();
          else stop();
        }),
      { rootMargin: '0px' },
    );
    io.observe(section);

    window.addEventListener('scroll', updateTarget, { passive: true });
    window.addEventListener(
      'resize',
      () => {
        if (!is3d() || transitioning) return;
        layout();
        updateTarget();
        render();
      },
      { passive: true },
    );

    // foco por teclado → rotar el cilindro para mostrar la card enfocada
    cards.forEach((c) => {
      c.el.querySelector('a')?.addEventListener('focus', () => {
        if (!is3d() || transitioning) return;
        const vi = active.indexOf(c);
        if (vi >= 0) scrollToIndex(vi);
      });
    });

    toggleBtn?.addEventListener('click', () => {
      if (transitioning) return;
      if (viewMode === 'cilindro') goGrilla();
      else goCilindro();
    });

    // ---- arranque: 3D si hay motion permitido; si no, grilla accesible sin toggle ----
    if (!reduce.matches) {
      section.classList.add('is-toggleable');
      viewMode = 'cilindro';
      syncToggle();
      enter3DInitial();
    } else {
      viewMode = 'grilla';
    }

    // Responder si la preferencia de movimiento cambia en runtime.
    reduce.addEventListener?.('change', (e) => {
      clearTimeout(flipTimer);
      transitioning = false;
      section!.classList.remove('is-flipping');
      if (e.matches) {
        // ahora pide menos movimiento → grilla fija, sin toggle
        stop();
        section!.classList.remove('is-toggleable', 'is-3d', 'is-scrolling');
        section!.classList.add('is-grid');
        dockControls(false);
        clearCylinderStyles();
        viewMode = 'grilla';
      } else {
        // vuelve a permitir movimiento → reactivar cilindro y toggle
        section!.classList.add('is-toggleable');
        viewMode = 'cilindro';
        syncToggle();
        enter3DInitial();
      }
    });
  }
</script>
