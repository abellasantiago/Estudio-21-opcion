---
import { Picture } from 'astro:assets';
import type { Integrante } from '../data/equipo';
import { getFotoEquipo, iniciales } from '../lib/images';

interface Props {
  persona: Integrante;
  /** delay del reveal (1..3) */
  d?: number;
}

const { persona, d = 1 } = Astro.props;
const foto = getFotoEquipo(persona.slug);
---

<div class="person reveal" data-d={d}>
  {foto ? (
    <div class="portrait">
      <Picture
        src={foto}
        formats={['avif', 'webp']}
        alt={`Retrato de ${persona.nombre}, ${persona.rol}`}
        widths={[240, 360, 480]}
        sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 360px"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="portrait is-placeholder">
      <span class="initials">{iniciales(persona.nombre)}</span>
      <span class="ptag">foto pendiente</span>
    </div>
  )}
  <div class="pname">{persona.nombre}</div>
  <div class="prole">{persona.rol}</div>
  <div class="ploc">{persona.ubicacion}</div>
</div>
