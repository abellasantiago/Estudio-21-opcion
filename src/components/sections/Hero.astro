---
import '../../styles/hero.css';
import { site } from '../../data/site';
---

<section class="hero">
  <span class="ghost21" aria-hidden="true">21</span>
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-main">
        <span class="eyebrow reveal">Arquitectura que trasciende</span>
        <h1 class="hero-title reveal" data-d="1">De la idea a la escritura, un solo <em>estudio</em>.</h1>
        <p class="hero-lead reveal" data-d="2">
          Concebimos el proyecto, conseguimos el terreno y estructuramos la
          inversión. Diseñamos, construimos, dirigimos la obra y vendemos. Todo
          el ciclo, con un mismo equipo.
        </p>
      </div>
      <div class="hero-side reveal" data-d="2">
        <div class="hero-dim">EST21 · {site.direccion.calle}</div>
      </div>
    </div>

    <div class="legend reveal" data-d="3">
      <div class="cell">
        <div class="num">+10</div>
        <div class="lab">Años de trayectoria</div>
      </div>
      <div class="cell">
        <div class="num">+15</div>
        <div class="lab">Proyectos ejecutados</div>
      </div>
      <div class="cell">
        <div class="num">06</div>
        <div class="lab">Profesionales</div>
      </div>
    </div>
  </div>
</section>
