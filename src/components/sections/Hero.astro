---
import '../../styles/hero.css';
// import HeroBlueprints from '../HeroBlueprints.astro'; // easter egg oculto por ahora
import HeroWireframe from '../HeroWireframe.astro';
import { site } from '../../data/site';

// "21" extruido: capas apiladas en Z (de lejos → al frente). El giro (rotateY)
// las muestra como un bloque con grosor en vez de texto plano. Material grafito
// mate: el canto (las capas de atrás, visibles al girar) va de un gris cálido
// iluminado en el fondo a casi negro contra la cara frontal → lee como un
// lateral sombreado con luz cenital. La cara del frente (`face`) no lleva color
// inline: lo pone el CSS (.ht-face), con un degradé tipo sheen si el navegador
// soporta background-clip:text.
const NUM_LAYERS = 16;
const numLayers = Array.from({ length: NUM_LAYERS }, (_, i) => {
  const t = i / (NUM_LAYERS - 1); // 0 = capa más lejana, 1 = cara al frente
  const z = -(1 - t) * 38; // px de profundidad (lejos: -38 → frente: 0)
  // oscurecimiento CUADRÁTICO (t²): la mayor parte del canto queda en el gris
  // iluminado y recién se funde a negro contra la cara → lateral liso y claro
  // como en la referencia, no un degradé parejo.
  const tt = t * t;
  const mix = (a: number, b: number) => Math.round(a + (b - a) * tt);
  // canto: rgb(122,118,109) (grafito iluminado) lejos → rgb(30,29,25) al frente
  const col = `rgb(${mix(122, 30)}, ${mix(118, 29)}, ${mix(109, 25)})`;
  return { z, col, face: i === NUM_LAYERS - 1 };
});

// "Estudio" también extruido (mismo efecto que el "21", pero más chato porque
// la palabra es más pequeña): mismo material grafito.
const WORD_LAYERS = 9;
const wordLayers = Array.from({ length: WORD_LAYERS }, (_, i) => {
  const t = i / (WORD_LAYERS - 1);
  const z = -(1 - t) * 14; // menos profundidad que el "21"
  const tt = t * t; // mismo material grafito que el "21"
  const mix = (a: number, b: number) => Math.round(a + (b - a) * tt);
  const col = `rgb(${mix(122, 34)}, ${mix(118, 33)}, ${mix(109, 28)})`;
  return { z, col, face: i === WORD_LAYERS - 1 };
});
---

<section class="hero" id="inicio">
  <!-- Tramo inicial: en modo inmersivo se vuelve alto y su progreso de scroll
       hace girar "Estudio 21". En fallback es un hero centrado normal. -->
  <div class="hero-track" data-immersive-intro>
    <div class="hero-stage">
      {/* <HeroBlueprints /> easter egg oculto por ahora */}

      <!-- pabellón wireframe a dos puntos de fuga, detrás del título -->
      <HeroWireframe />

      <span class="eyebrow hero-eyebrow reveal">Arquitectura que trasciende</span>

      <div class="hero-title-wrap" data-depth="0.12">
        <h1 class="hero-title" data-immersive-title>
          <span class="ht-word" aria-hidden="true">
            <span class="ht-word-3d">
              {wordLayers.map((l) =>
                l.face ? (
                  <span class="ht-word-layer ht-face" style={`--z:${l.z}px`}>Estudio</span>
                ) : (
                  <span class="ht-word-layer" style={`--z:${l.z}px; color:${l.col}`}>Estudio</span>
                ),
              )}
            </span>
          </span>
          <span class="ht-num" aria-hidden="true">
            <span class="ht-num-3d">
              {numLayers.map((l) =>
                l.face ? (
                  <span class="ht-num-layer ht-face" style={`--z:${l.z}px`}>21</span>
                ) : (
                  <span class="ht-num-layer" style={`--z:${l.z}px; color:${l.col}`}>21</span>
                ),
              )}
              <!-- sombra proyectada: plano horizontal bajo los dígitos, DENTRO
                   del bloque preserve-3d → rota en el piso junto con el "21" -->
              <span class="ht-shadow"></span>
            </span>
          </span>
          <span class="sr-only">Estudio 21</span>
        </h1>
      </div>

      <div class="hero-dim" data-depth="0.7">{site.direccion.calle}</div>

      <div class="scroll-hint" data-scroll-hint aria-hidden="true">
        <span class="scroll-hint-line"></span>
        <span class="scroll-hint-label">scroll</span>
      </div>
    </div>
  </div>

  <!-- Contenido: aparece al final del giro / debajo del hero en fallback. -->
  <div class="hero-intro wrap">
    <p class="hero-claim reveal">De la idea a la escritura, un solo <em>estudio</em>.</p>
    <p class="hero-lead reveal" data-d="1">
      Concebimos el proyecto, conseguimos el terreno y estructuramos la
      inversión. Diseñamos, construimos, dirigimos la obra y vendemos. Todo el
      ciclo, con un mismo equipo.
    </p>

    <div class="legend reveal" data-d="2">
      <div class="cell">
        <div class="num">+10</div>
        <div class="lab">Años de trayectoria</div>
      </div>
      <div class="cell">
        <div class="num">+15</div>
        <div class="lab">Proyectos ejecutados</div>
      </div>
      <div class="cell">
        <div class="num">06</div>
        <div class="lab">Profesionales</div>
      </div>
    </div>
  </div>
</section>
