---
import '../../styles/hero.css';
import { site } from '../../data/site';
---

<section class="hero" id="inicio">
  <!-- Tramo inicial: en modo inmersivo se vuelve alto y su progreso de scroll
       hace girar "Estudio 21". En fallback es un hero centrado normal. -->
  <div class="hero-track" data-immersive-intro>
    <div class="hero-stage">
      <span class="eyebrow hero-eyebrow reveal">Arquitectura que trasciende</span>

      <div class="hero-title-wrap" data-depth="0.12">
        <h1 class="hero-title" data-immersive-title>
          <span class="ht-word">Estudio</span>
          <span class="ht-num">21</span>
        </h1>
      </div>

      <div class="hero-dim" data-depth="0.7">EST21 · {site.direccion.calle}</div>

      <div class="scroll-hint" data-scroll-hint aria-hidden="true">
        <span class="scroll-hint-line"></span>
        <span class="scroll-hint-label">scroll</span>
      </div>
    </div>
  </div>

  <!-- Contenido: aparece al final del giro / debajo del hero en fallback. -->
  <div class="hero-intro wrap">
    <p class="hero-claim reveal">De la idea a la escritura, un solo <em>estudio</em>.</p>
    <p class="hero-lead reveal" data-d="1">
      Concebimos el proyecto, conseguimos el terreno y estructuramos la
      inversión. Diseñamos, construimos, dirigimos la obra y vendemos. Todo el
      ciclo, con un mismo equipo.
    </p>

    <div class="legend reveal" data-d="2">
      <div class="cell">
        <div class="num">+10</div>
        <div class="lab">Años de trayectoria</div>
      </div>
      <div class="cell">
        <div class="num">+15</div>
        <div class="lab">Proyectos ejecutados</div>
      </div>
      <div class="cell">
        <div class="num">06</div>
        <div class="lab">Profesionales</div>
      </div>
    </div>
  </div>
</section>
