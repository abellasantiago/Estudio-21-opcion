---
// Fuentes servidas localmente con Fontsource (sólo los pesos que usa el diseño).
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Activa la capa inmersiva (sólo la home). */
  immersive?: boolean;
}

const { title, description, image, jsonLd, immersive = false } = Astro.props;

// Se agrega `is-immersive` lo antes posible (antes del primer paint) para evitar
// el flash del layout de fallback. El motor (immersive.ts) toma el control en runtime.
const immersiveBoot = `(function(){try{var m=window.matchMedia;if(m&&!m('(prefers-reduced-motion: reduce)').matches&&m('(pointer: fine)').matches&&m('(min-width: 900px)').matches){document.documentElement.classList.add('is-immersive')}}catch(e){}})()`;
---

<!doctype html>
<html lang="es" data-immersive-page={immersive ? '' : undefined}>
  <head>
    <BaseHead title={title} description={description} image={image} jsonLd={jsonLd} />
    {immersive && <script is:inline set:html={immersiveBoot} />}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />

    <script>
      // ----- capa inmersiva (no-op fuera de la home) -----
      import { initImmersive } from '../scripts/immersive';
      initImmersive();

      // ----- header con sombra al hacer scroll -----
      const header = document.getElementById('header');
      if (header) {
        const onScroll = () => {
          header.classList.toggle('scrolled', window.scrollY > 8);
          // en la home inmersiva el header arranca oculto y aparece al pasar el
          // hero (la clase sólo tiene efecto bajo html.is-immersive, ver CSS).
          header.classList.toggle('past-hero', window.scrollY > window.innerHeight * 0.7);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ----- menú móvil -----
      const burger = document.getElementById('burger');
      if (burger) {
        burger.addEventListener('click', () => {
          const open = document.body.classList.toggle('menu-open');
          burger.setAttribute('aria-expanded', String(open));
          burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
        });
        document.querySelectorAll('#menu a').forEach((a) =>
          a.addEventListener('click', () => {
            document.body.classList.remove('menu-open');
            burger.setAttribute('aria-expanded', 'false');
          }),
        );
      }

      // ----- reveal on scroll (respeta prefers-reduced-motion) -----
      const reveals = document.querySelectorAll('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        reveals.forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
