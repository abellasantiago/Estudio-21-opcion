---
// Fuentes servidas localmente (archivos woff2 de Fontsource, subset latin —
// cubre todo el español), pero con las @font-face declaradas ACÁ y no vía los
// .css del paquete. Motivo: los .css de Fontsource usan `font-display: swap` y
// el navegador recién pide la fuente después de parsear CSS + layout → en un
// refresh el primer paint corría con la fuente fallback del sistema y un frame
// después entraba Space Grotesk = "pantallazo" de un 21 distinto (y fantasmas
// distintos). Acá: `<link rel="preload">` de cada woff2 (misma URL que el
// @font-face, arranca a bajar a los ~0 ms) + `font-display: block` (si aun así
// no llegara al primer paint, el texto espera invisible — NUNCA pinta glifos
// de otra fuente).
import sg400 from '@fontsource/space-grotesk/files/space-grotesk-latin-400-normal.woff2?url';
import sg500 from '@fontsource/space-grotesk/files/space-grotesk-latin-500-normal.woff2?url';
import sg700 from '@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2?url';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import mono400 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';
import mono500 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-500-normal.woff2?url';
import '../styles/global.css';

const fontFaces = [
  { family: 'Space Grotesk', weight: 400, url: sg400 },
  { family: 'Space Grotesk', weight: 500, url: sg500 },
  { family: 'Space Grotesk', weight: 700, url: sg700 },
  { family: 'Inter', weight: 400, url: inter400 },
  { family: 'Inter', weight: 500, url: inter500 },
  { family: 'IBM Plex Mono', weight: 400, url: mono400 },
  { family: 'IBM Plex Mono', weight: 500, url: mono500 },
];
const fontFaceCss = fontFaces
  .map(
    (f) =>
      `@font-face{font-family:'${f.family}';font-style:normal;font-weight:${f.weight};` +
      `font-display:block;src:url(${f.url}) format('woff2')}`,
  )
  .join('');

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import Preloader from '../components/Preloader.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Activa la capa inmersiva (sólo la home). */
  immersive?: boolean;
}

const { title, description, image, jsonLd, immersive = false } = Astro.props;

// Se agrega `is-immersive` lo antes posible (antes del primer paint) para evitar
// el flash del layout de fallback. El motor (immersive.ts) toma el control en runtime.
const immersiveBoot = `(function(){try{var m=window.matchMedia;if(m&&!m('(prefers-reduced-motion: reduce)').matches&&m('(pointer: fine)').matches&&m('(min-width: 900px)').matches){document.documentElement.classList.add('is-immersive')}}catch(e){}})()`;
---

<!doctype html>
<html lang="es" data-immersive-page={immersive ? '' : undefined}>
  <head>
    <!-- fuentes: preload de cada woff2 (misma URL que su @font-face de abajo —
         el `crossorigin` es obligatorio en preloads de fuentes, aun same-origin,
         si no el navegador la baja DOS veces) + @font-face con font-display:block
         → el "21" pinta directo con Space Grotesk, sin frame de fuente fallback. -->
    {fontFaces.map((f) => (
      <link rel="preload" as="font" type="font/woff2" href={f.url} crossorigin="anonymous" />
    ))}
    <style is:inline set:html={fontFaceCss} />
    <BaseHead title={title} description={description} image={image} jsonLd={jsonLd} />
    {immersive && <script is:inline set:html={immersiveBoot} />}
    <slot name="head" />
  </head>
  <body>
    {immersive && <Preloader />}
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
    <FloatingWhatsApp />

    <script>
      // ----- recargar arranca arriba (en la home, el hero) -----
      // Por defecto el navegador restaura la posición de scroll al recargar; lo
      // desactivamos para volver siempre al inicio, salvo que se llegue con un
      // ancla (#seccion), donde respetamos el destino del fragmento.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (!window.location.hash) window.scrollTo(0, 0);

      // ----- capa inmersiva (no-op fuera de la home) -----
      import { initImmersive } from '../scripts/immersive';
      initImmersive();

      // ----- header con sombra al hacer scroll -----
      const header = document.getElementById('header');
      if (header) {
        const onScroll = () => {
          header.classList.toggle('scrolled', window.scrollY > 8);
          // en la home inmersiva el header arranca oculto y aparece al pasar el
          // hero (la clase sólo tiene efecto bajo html.is-immersive, ver CSS).
          header.classList.toggle('past-hero', window.scrollY > window.innerHeight * 0.7);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // ----- menú móvil -----
      const burger = document.getElementById('burger');
      if (burger) {
        burger.addEventListener('click', () => {
          const open = document.body.classList.toggle('menu-open');
          burger.setAttribute('aria-expanded', String(open));
          burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
        });
        document.querySelectorAll('#menu a').forEach((a) =>
          a.addEventListener('click', () => {
            document.body.classList.remove('menu-open');
            burger.setAttribute('aria-expanded', 'false');
          }),
        );
      }

      // ----- reveal on scroll (respeta prefers-reduced-motion) -----
      const reveals = document.querySelectorAll('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        reveals.forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
