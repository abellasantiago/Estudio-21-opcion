---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Nosotros from '../components/sections/Nosotros.astro';
import ProyectosHelicoidal from '../components/ProyectosHelicoidal.astro';
import Estudio from '../components/sections/Estudio.astro';
import Contacto from '../components/sections/Contacto.astro';
import { site } from '../data/site';

const title = 'Estudio 21 — Arquitectura y desarrollo · Montevideo';
const description = site.descripcion;
---

<BaseLayout title={title} description={description}>
  <Hero />
  <Nosotros />
  <ProyectosHelicoidal />
  <Estudio />
  <Contacto />
</BaseLayout>
